{
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://filmate-backendv.onrender.com/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
